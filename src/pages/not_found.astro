---
import SiteLayout from "../layouts/SiteLayout.astro";
import Footer from "../components/Footer.astro";
import Logo from "../components/Logo.astro";
import TopNav from "../components/TopNav.astro";
---

<SiteLayout pageTitle="404 — lunaui">
    <main id="error-main">
        <Logo/>
        <TopNav/>

        <fieldset id="error-content" class="box-container">
            <legend>404</legend>
            <h1 id="error-code">404<span id="error-blink">_</span></h1>
            <p id="error-sub">womp womp...</p>
            <p id="error-msg">it seems you wandered a bit too far and found a page that doesn't exist!</p>
            <a href="/" id="error-home">&#8592; go home</a>
        </fieldset>

        <Footer/>
    </main>
</SiteLayout>

<style>
#error-main {
    padding: 3vh 0 0 0;
    gap: 0.5em;
    display: grid;
    grid-template:
        "logo logo top-nav top-nav top-nav" auto
        "error-content error-content error-content error-content error-content" 1fr
        "footer footer footer footer footer" auto / 1fr 0.25fr 0.75fr 1fr 1fr;
    min-height: calc(100vh - 3vh);
}

#error-content {
    grid-area: error-content;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 0.5em;
    padding: 3em 1em;
}

#error-code {
    font-size: 5rem;
    font-weight: bold;
    color: #e0f2fe;
    margin: 0;
    text-shadow: 0 0 10px #a4d3ff88;
}

#error-blink {
    animation: blink 1s step-end infinite;
    color: #a4d3ff;
}

@keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
}

#error-sub {
    font-size: 1.1rem;
    color: #64748b;
    margin: 0;
}

#error-msg {
    font-size: 0.9rem;
    color: #94a3b8;
    margin: 0.5em 0 1em 0;
    max-width: 400px;
}

#error-home {
    font-size: 0.9rem;
    color: #a4d3ff;
    text-decoration: none;
    border: 1px dashed #a4d3ff66;
    padding: 0.4em 1em;
}

#error-home:hover {
    border-color: #a4d3ff;
    background-color: #a4d3ff11;
}
</style>