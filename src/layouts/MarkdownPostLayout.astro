---
import BlogLayout from "./BlogLayout.astro";
import ILunauiLogo from "@images/luna-logo.png";

const { frontmatter } = Astro.props;

const imageAssets = import.meta.glob<{ default: { src: string } }>(
    '/src/assets/images/**/*.{png,jpg,jpeg,gif,webp,avif,svg}',
    { eager: true }
);

function resolveBanner(raw: string | undefined): string {
    if (!raw) return ILunauiLogo.src;
    const key = raw.startsWith('@images/')
        ? raw.replace('@images/', '/src/assets/images/')
        : null;
    if (key && imageAssets[key]) return imageAssets[key].default.src;
    return raw;
}

const banner = resolveBanner(frontmatter.banner);
---

<BlogLayout pageTitle="" isPost={true}>
    <div id="post-banner" style={`--banner-url: url('${banner}')`}>
        <div id="post-header">
            <a href="/blog/" id="post-back">&#8592; back to blog</a>
            <span id="post-date">{frontmatter.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            <h1 id="post-title">{frontmatter.title}</h1>
            <p id="post-desc">{frontmatter.description}</p>
            <div id="post-tags">
                {frontmatter.tags.map((tag: string) => (
                    <span class="blog-tag">{tag}</span>
                ))}
            </div>
        </div>
    </div>

    <div id="post-body">
        <slot/>
    </div>
</BlogLayout>